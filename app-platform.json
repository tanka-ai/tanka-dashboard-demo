{
  "appId": "dashboard-demo",
  "name": "积分运营看板",
  "kind": "points-dashboard",
  "builderMode": "edit",
  "runtime": "nextjs",
  "description": "面向企业团队的积分工作台，覆盖个人成长、任务获分、团队排行、流水结算和权益兑换。",
  "deployment": {
    "provider": "vercel",
    "status": "local-prototype"
  },
  "views": [
    {
      "id": "points-dashboard",
      "name": "积分看板",
      "route": "/",
      "description": "聚合积分余额、成长等级、团队排行、任务进度与兑换权益。"
    }
  ],
  "dataSources": [
    {
      "provider": "airtable",
      "status": "not_configured",
      "requiredEnv": [
        "AIRTABLE_API_KEY",
        "AIRTABLE_BASE_ID",
        "AIRTABLE_TABLE_POINTS_USERS",
        "AIRTABLE_TABLE_POINTS_LEDGER",
        "AIRTABLE_TABLE_POINTS_TASKS",
        "AIRTABLE_TABLE_POINTS_REWARDS"
      ],
      "entities": [
        "UserPointsProfile",
        "PointsBreakdownItem",
        "PointLedgerEntry",
        "TeamPointsLeaderboardEntry",
        "PointsTask",
        "RewardCatalogItem",
        "PointsHighlight"
      ]
    }
  ]
}
